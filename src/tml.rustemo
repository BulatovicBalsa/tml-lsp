//
// Grammar definition for TML
//

translation_unit            : ext_decls=external_declaration+
                            ;

external_declaration        : function_definition
                            | declaration_statement
                            | assignment_statement
                            ;

function_definition         : 'fn' id=id '(' parameters_list=parameter*[comma] ')' ret_type=type_spec? ':'
                               statement_block=statement_block 'end'
                            ;

parameter                   : _type=type_spec id=id default=default_param_value?
                            ;

default_param_value         : '=' value=expression
                            ;

type_cast_expression        : _type=type_spec '(' expr=expression ')'
                            ;

type_spec                   : simple_type
                            | derived_type
                            | tensor_constructor
                            ;

simple_type                 : _type=simple_type_spec
                            ;

derived_type                : name=dot_access_expression
                              brackets='[]'* //better put '[' ']', but causes S/R conflict
                              type_kw
                            ;

simple_type_spec            : 'int' | 'uint' | 'real' | 'bool' | 'str' ;

tensor_constructor          : 'tensor'
                              '<'
                              _type=type_spec
                              comma
                              dimensions=expression+[comma]
                              '>'
                            ;

//alternative shorter notation for tensor type constructor
//tensor_constructor          : _type=type_spec
//                              '['
//                              dimensions=expression+[comma]
//                              ']'
//                            ;

statement_block             : statements=statement+
                            ;

statement                   : function_call
                            | selection_statement
                            | iteration_statement
                            | jump_statement
                            | exists_statement
                            | not_exists_statement
                            | assignment_statement
                            | declaration_statement
                            ;

function_call_statement     : function_call
                            ;

selection_statement         : 'if' condition=expression ':' if_statement_block=statement_block
                              elseif_clause=elseif_clause*
                              else_clause=else_clause? 'end'
                            ;

else_clause                 : 'else' ':' else_statement_block=statement_block
                            ;

elseif_clause               : 'elseif' condition=expression ':' elseif_statement_block=statement_block
                            ;

iteration_statement         : for_iteration_statement
                            | while_iteration_statement
                            ;

for_iteration_statement     : 'for' idx=id '=' iterator_expression=expression ':' statement_block=statement_block 'end'
                            ;

while_iteration_statement   : 'while' condition=expression ':' statement_block=statement_block 'end'
                            ;

jump_statement              : break_statement
                            | return_statement
                            | continue_statement
                            ;

break_statement             : 'break';
continue_statement          : 'continue';

return_statement            : empty_return
                            | return_value
                            ;

empty_return                : 'return' {shift};

return_value                : 'return' ret_val=expression;

exists_statement            : 'exists' guarded=dot_access_expression+[comma] ':'
                              statement_block=statement_block
                              else_clause=else_clause? 'end'
                            ;

not_exists_statement        : 'not' 'exists' guarded=dot_access_expression+[comma] ':'
                              statement_block=statement_block
                              else_clause=else_clause? 'end'
                            ;

assignment_statement        : var_assignment_statement
                            | tensor_assignment_statement
                            ;

// shift in the following rules are used to make expression greedy
var_assignment_statement    : var=dot_access_expression op=assignment_operator rvalue=expression {shift}
                            ;

tensor_assignment_statement : tensor=lvalue_tensor op=assignment_operator rvalue=expression {shift}
                            ;

declaration_statement       : _type=type_spec id=id '=' rvalue=expression {shift}
                            ;

expression                  : logical_expression
                            | type_cast_expression
                            | math_expression
                            ;

attribute_access            : expr=expression dot attr=id
                            ;

assignment_operator         : '=' | '*=' | '/=' | '%=' | '+=' | '-='
                            ;

logical_expression          : binary_relational_expression
                            | binary_logical_expression
                            | unary_logical_expression
                            ;

binary_logical_expression   : left_expr=expression op='or'  right_expr=expression {left, 1}
                            | left_expr=expression op='and' right_expr=expression  {left, 2}
                            ;

unary_logical_expression    : op='not'  expr=expression                                     {right, 3}
                            ;

binary_relational_expression     : left_expr=expression op='==' right_expr=expression     {left, 4}
                                 | left_expr=expression op='!=' right_expr=expression     {left, 4}
                                 | left_expr=expression op='>'  right_expr=expression     {left, 4}
                                 | left_expr=expression op='<'  right_expr=expression     {left, 4}
                                 | left_expr=expression op='>=' right_expr=expression     {left, 4}
                                 | left_expr=expression op='<=' right_expr=expression     {left, 4}
                                 ;

math_expression            : postfix_expression
                           | binary_math_expression
                           | unary_math_expression
                           | elvis_expression
                           ;

elvis_expression           : left_expr=expression '?:'  right_expr=expression {left, 5}
                           ;

binary_math_expression     : left_expr=expression op='+'  right_expr=expression {left, 5}
                           | left_expr=expression op='-'  right_expr=expression {left, 5}
                           | left_expr=expression op='%'  right_expr=expression {left, 6}
                           | left_expr=expression op='*'  right_expr=expression {left, 6}
                           | left_expr=expression op='/'  right_expr=expression {left, 6}
                           | left_expr=expression op='\\' right_expr=expression {left, 6} //should this be removed?
                           | left_expr=expression op='**' right_expr=expression {left, 8}
                           ;

unary_math_expression      : op='-' expr=expression                             {right, 7}
                           | op='+' expr=expression                             {right, 7}
                           ;


postfix_expression         : rvalue
                           | constant
                           | expr_in_parenthesis
                           | transpose_expression
                           | tensor_literal
                           | tensor_expression
                           | function_call
                           | attribute_access
                           | range_expression
                           ;

// rvalue is a wrapper used for simplifying handling of undeclared variable errors
rvalue                     : _ref=dot_access_expression
                           ;

range_expression           : range_without_step_expression
                           | range_with_step_expression
                           ;

range_operand              : rvalue
                           | constant
                           | expr_in_parenthesis
                           | function_call
                           ;

range_without_step_expression : start=range_operand dots stop=range_operand        {shift}
                              ;

range_with_step_expression    : start=range_operand dots stop=range_operand dots step=range_operand
                              ;

expr_in_parenthesis        : '(' expr=expression ')'
                           ;

tensor_literal             : '[' expr=cube ']'
                           ;

transpose_expression       : postfix_expression '\''  // transpose operator <'>
                           ;

function_call              : id=id '(' arguments_list=argument*[comma] ')'
                           ;

index_expression_list      : index_expression_list=index_expression+[comma]
                           ;

index_expression           : index_copy_expr
                           | index_from_position
                           | index_bounds
                           | index_bounds_step
                           | index_upper_bound
                           | index_lower_bound
                           ;

index_copy_expr            : expr=':'
                           ;

index_from_position        : expr=expression
                           ;

index_bounds               : lower_bound=expression ':' upper_bound=expression
                           ;

index_bounds_step          : lower_bound=expression ':' upper_bound=expression ':' step=expression
                           ;

index_upper_bound          : ':' upper_bound=expression
                           ;

index_lower_bound          : lower_bound=expression ':'
                           ;

arguments_list             : arguments_list=argument+[comma]
                           ;

argument                   : id=id '=' value=expression
                           | value=expression
                           ;

lvalue_tensor              : expr=dot_access_expression
                             indices=index+
                           ;
index                      : '[' index=index_expression_list ']'
                           ;

tensor_expression          : expr=expression '[' index=index_expression_list ']'
                           ;

dot_access_expression      : names=id+[dot]
                             optional='?'?
                           ;

array                      : elements=expression+[comma]
                           ;

matrix                     : elements=array+[semicolon]
                           ;

cube                       : elements=matrix+[pipe]
                           ;

constant                    : integer
                            | unsigned_integer
                            | float
                            | string
                            | boolean
                            ;

boolean                     : value=boolean_const
                            ;

integer                     : value=integer_const
                            | value=hexadecimal_const
                            | value=binary_const
                            ;

unsigned_integer            : value=unsigned_integer_const
                            | value=unsigned_hexadecimal_const
                            | value=unsigned_binary_const
                            ;

float                       : value=float_const
                            ;

string                      : value=string_const
                            ;

// Needed for comments in our language
LAYOUT: LayoutItem | LAYOUT LayoutItem | EMPTY;
LayoutItem: WS | Comment;





// ===================================== Terminals
terminals

square_brackets: '[]';
question: '?';
func: 'fn';
oparen: '(';
cparen: ')';
colon: ':';
endt: 'end';
assign: '=';
intt: 'int';
uintt: 'uint';
realt: 'real';
boolt: 'bool';
strt: 'str';
tensort: 'tensor';
lt: '<';
gt: '>';
le: '<=';
ge: '>=';
eq: '==';
ift: 'if';
elset: 'else';
elseift: 'elseif';
fort: 'for';
whilet: 'while';
breakt: 'break';
continuet: 'continue';
returnt: 'return';
existst: 'exists';
nott: 'not';
mulassignt: '*=';
divassignt: '/=';
addassignt: '+=';
subassignt: '-=';
modassignt: '%=';
ort: 'or';
andt: 'and';
noteqt: '!=';
elvist: '?:';
addt: '+';
subt: '-';
modt: '%';
mult: '*';
divt: '/';
rwdivt: '\\\\';
rdivt: '\\';
powt: '**';
osquare: '[';
csquare: ']';
transpose: '\'';


unsigned_suffix: /[uU]/ ;

// NOTE: Minus sign '-' in the following terminals is never match, because of the
// '-' math_expression rule.

integer_const: /[-+]?[0-9]+(_[0-9]+)*/ {prefer} ;
unsigned_integer_const: /[-+]?[0-9]+(_[0-9]+)*[uU]/ {prefer} ;
hexadecimal_const: /0[xX][0-9a-fA-F]+/ ;
unsigned_hexadecimal_const: /0[xX][0-9a-fA-F]+[uU]/ {prefer} ;
binary_const: /0[bB][01]+/ ;
unsigned_binary_const: /0[bB][01]+[uU]/                 {prefer} ;

// valid reals 1.5, 1e10, 1_1e1_1 as in Octave
float_const: /[-+]?[0-9]+(_[0-9]+)*(\.[0-9]+(_[0-9]+)*)?([eE][+-]?[0-9]+(_[0-9]+)*)?/ ;
boolean_const: /true|false/ {prefer};

ellipsis: '...';
dot: '.';
dots: '..';
comma: ',';
semicolon: ';';
pipe: '|';
type_kw: '.type';

string_const: /("([^"\\\n]|(\\(([a-zA-Z._~!=&\^\-\\?'"])|(\d+)|(x[0-9a-fA-F]+))))*")|('([^'\\\n]|(\\(([a-zA-Z._~!=&\^\-\\?'"])|(\d+)|(x[0-9a-fA-F]+))))*')/;
id: /(?!type)[_a-zA-Z][_a-zA-Z0-9]*/;
KEYWORD: /\w+/;

// Needed for comments in our language
WS: /\s+/;
Comment: /\#.*/;
